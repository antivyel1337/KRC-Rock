        if(text !== wanted) continue;
        var node = heading.nextElementSibling;
        var hops = 0;
        while(node && hops < 8){
          if(node.matches && node.matches("select")) return node;
          var nestedSelect = node.querySelector ? node.querySelector("select") : null;
