            parseSrcset(el.getAttribute("srcset"))
          ].forEach(function(url){
            var clean = cleanUrl(url);
            if(clean && clean.indexOf("data:") !== 0){
              candidates.push({
                url: clean,
                score: scoreImage(el, clean)
              });
            }
          });
        });
      });
      [
