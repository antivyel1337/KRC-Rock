      };
    }
    if(resetBtn){
      resetBtn.onclick = function(){
        stopTipAttention();
        clearMessage();
        if(areaInput) areaInput.value = "";
        if(sealerSurfaceInput) sealerSurfaceInput.value = "150";
        if(sealerCoatsInput) sealerCoatsInput.value = "2";
        if(sealerWasteInput) sealerWasteInput.value = "5";
        if(depthInput) depthInput.value = "1";
        if(flagThicknessInput) flagThicknessInput.selectedIndex = 0;
        if(copingLfInput) copingLfInput.value = "";
        if(copingWasteInput) copingWasteInput.value = "10";
        if(copingSizeInput) copingSizeInput.selectedIndex = 0;
        if(ezMixLengthInput) ezMixLengthInput.value = "";
if(ezMixWidthInput) ezMixWidthInput.value = "";
if(ezMixThicknessInput) ezMixThicknessInput.value = "4";
if(ezMixWasteInput) ezMixWasteInput.value = "5";
if(ocBlockLengthInput) ocBlockLengthInput.value = "";
if(ocBlockHeightInput) ocBlockHeightInput.value = "";
if(ocBlockWasteInput) ocBlockWasteInput.value = "5";
        var widthEl = document.getElementById("krcCqcVeneerWidth");
        var heightEl = document.getElementById("krcCqcVeneerHeight");
        var openingsEl = document.getElementById("krcCqcVeneerOpenings");
        var wasteEl = document.getElementById("krcCqcVeneerWaste");
        var cornersEl = document.getElementById("krcCqcVeneerCorners");
        if(widthEl) widthEl.value = "";
        if(heightEl) heightEl.value = "";
        if(openingsEl) openingsEl.value = "";
        if(wasteEl) wasteEl.value = "12";
        if(cornersEl) cornersEl.value = "";
        if(resultValue) resultValue.textContent = "0";
        if(subResultValue) subResultValue.textContent = "0";
        if(resultWrap) resultWrap.style.display = "none";
        if(subResultWrap) subResultWrap.style.display = "none";
        if(addEstimateBtn) addEstimateBtn.style.display = "none";
        refreshModeUI();
      };
    }
    if(addEstimateBtn){
      addEstimateBtn.onclick = function(){
        stopTipAttention();
        var result = calculateEstimate();
        if(result && result.qty > 0){
          addToQuote(result.qty, addEstimateBtn, result);
        }
      };
    }
      if(minusBtn){
        minusBtn.onclick = function(){
          stopTipAttention();
          clearMessage();
          var current = getCustomQty();
          var mode = getMaterialMode();
          var wholeNumberMode = (
            mode === "quoteonly" ||
            mode === "coping" ||
            mode === "ezmix" ||
            mode === "ocblock"
          );
          var step = wholeNumberMode ? 1 : 0.5;
          var min = wholeNumberMode ? 1 : 0.5;
          qtyInput.value = Math.max(min, current - step);
        };
      }
      if(plusBtn){
        plusBtn.onclick = function(){
          stopTipAttention();
          clearMessage();
          var current = getCustomQty();
          var mode = getMaterialMode();
          var wholeNumberMode = (
            mode === "quoteonly" ||
            mode === "coping" ||
            mode === "ezmix" ||
            mode === "ocblock"
          );
          var step = wholeNumberMode ? 1 : 0.5;
          qtyInput.value = current + step;
        };
      }
      if(addCustomBtn){
        addCustomBtn.onclick = function(){
          stopTipAttention();
          clearMessage();
          addToQuote(getCustomQty(), addCustomBtn);
        };
      }
    if(depthInput){
      depthInput.onchange = function(){
        stopTipAttention();
        refreshModeUI();
      };
    }
    if(flagThicknessInput){
      flagThicknessInput.onchange = function(){
        stopTipAttention();
        refreshModeUI();
      };
    }
    if(copingSizeInput){
      copingSizeInput.onchange = function(){
        stopTipAttention();
        refreshModeUI();
      };
    }
    if(sealerSurfaceInput){
      sealerSurfaceInput.onchange = function(){
        stopTipAttention();
        refreshModeUI();
      };
    }
    if(sealerCoatsInput){
      sealerCoatsInput.onchange = function(){
        stopTipAttention();
        refreshModeUI();
      };
    }
    if(sealerWasteInput){
      sealerWasteInput.onchange = function(){
        stopTipAttention();
        refreshModeUI();
      };
    }
    [
  areaInput,
  qtyInput,
  copingLfInput,
  copingWasteInput,
  depthInput,
  flagThicknessInput,
  copingSizeInput,
  sealerSurfaceInput,
  sealerCoatsInput,
  sealerWasteInput,
  ezMixLengthInput,
  ezMixWidthInput,
  ezMixThicknessInput,
  ezMixWasteInput,
  ocBlockLengthInput,
  ocBlockHeightInput,
  ocBlockWasteInput
].forEach(function(el){
      if(!el) return;
      ["focus","input","change","click","touchstart"].forEach(function(evt){
        el.addEventListener(evt, stopTipAttention, { passive:true });
      });
    });
    syncQuoteIndicators(getQuoteItems());
    if(tip){
      tip.classList.add("is-attention");
    }
    window.setTimeout(refreshModeUI, 250);
    window.setTimeout(refreshModeUI, 1000);
    window.setTimeout(refreshModeUI, 2000);
  })();
 </script>
