<section id="krcCompactQuoteCalc">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
  <div class="krc-cqc-card">
   <div class="krc-cqc-head">
    <h3>
     Material Calculator
    </h3>
    <div class="krc-cqc-tip" id="krcCqcTip">
     <span class="krc-cqc-tip-arrow krc-cqc-tip-arrow-left" aria-hidden="true">
      &gt;&gt;
     </span>
     <span class="krc-cqc-tip-text">
      Estimate material, then add it directly to your quote.
     </span>
     <span class="krc-cqc-tip-arrow krc-cqc-tip-arrow-right" aria-hidden="true">
      &lt;&lt;
     </span>
    </div>
   </div>
   <div class="krc-cqc-block" id="krcCqcAreaWrap">
    <label for="krcCqcArea">
     Area (sq ft)
    </label>
    <input id="krcCqcArea" type="number" min="0" step="0.1" placeholder="Ex: 200">
   </div>
   <div class="krc-cqc-block" id="krcCqcSealerWrap" style="display:none;">
    <div class="krc-cqc-row" style="grid-template-columns:1fr 1fr;">
     <div class="krc-cqc-block">
      <label for="krcCqcSealerSurface">
       Surface Type
      </label>
      <select id="krcCqcSealerSurface">
       <option value="200">
        Dense Concrete (200 sqft/gal)
       </option>
       <option value="150" selected="">
        Pavers / Standard Stone (150 sqft/gal)
       </option>
       <option value="100">
        Porous Stone / Masonry (100 sqft/gal)
       </option>
       <option value="75">
        Very Porous Surface (75 sqft/gal)
       </option>
      </select>
     </div>
     <div class="krc-cqc-block">
      <label for="krcCqcSealerCoats">
       Coats
      </label>
      <select id="krcCqcSealerCoats">
       <option value="1">
        1 Coat
       </option>
       <option value="2" selected="">
        2 Coats
       </option>
      </select>
     </div>
    </div>
    <div class="krc-cqc-row" style="grid-template-columns:1fr 110px;">
     <div class="krc-cqc-block">
      <label for="krcCqcSealerWaste">
       Waste Factor
      </label>
      <select id="krcCqcSealerWaste">
       <option value="0">
        0%
       </option>
       <option value="5" selected="">
        5%
       </option>
       <option value="10">
        10%
       </option>
       <option value="15">
        15%
       </option>
      </select>
     </div>
     <div class="krc-cqc-block">
      <label>
       Unit
      </label>
      <div class="krc-cqc-unit">
       GALLONS
      </div>
     </div>
    </div>
    <div class="krc-cqc-boulder-note" style="margin-top:4px;">
     <strong>
      Coverage Estimate
     </strong>
     <span>
      Actual coverage varies by surface texture, porosity, product type, and application method. This is a planning estimate only.
     </span>
    </div>
   </div>
   <div class="krc-cqc-row" id="krcCqcStandardRow">
    <div class="krc-cqc-block">
     <label for="krcCqcDepth">
      Depth
     </label>
     <select id="krcCqcDepth">
      <option value="1">
       1 inch
      </option>
      <option value="2">
       2 inches
      </option>
      <option value="3">
       3 inches
      </option>
      <option value="4">
       4 inches
      </option>
      <option value="6">
       6 inches
      </option>
     </select>
    </div>
    <div class="krc-cqc-block">
     <label>
      Unit
     </label>
     <div class="krc-cqc-unit" id="krcCqcUnitBadge">
      YARDS
     </div>
    </div>
   </div>
   <div class="krc-cqc-block" id="krcCqcFlagstoneThicknessWrap" style="display:none;">
    <label for="krcCqcFlagThickness">
     Flagstone Thickness
    </label>
    <select id="krcCqcFlagThickness">
     <option value="150">
      3/4" (150 sqft/ton)
     </option>
     <option value="130">
      1" (130 sqft/ton)
     </option>
     <option value="110">
      1.5" (110 sqft/ton)
     </option>
     <option value="100">
      2" (100 sqft/ton)
     </option>
     <option value="80">
      3" (80 sqft/ton)
     </option>
     <option value="60">
      4" (60 sqft/ton)
     </option>
    </select>
   </div>
   <div class="krc-cqc-block" id="krcCqcCopingWrap" style="display:none;">
    <div class="krc-cqc-row" style="grid-template-columns:1fr 1fr;">
     <div class="krc-cqc-block">
      <label for="krcCqcCopingLf">
       Total Linear Feet
      </label>
      <input id="krcCqcCopingLf" type="number" min="0" step="0.1" placeholder="Ex: 88">
     </div>
     <div class="krc-cqc-block">
      <label for="krcCqcCopingWaste">
       Waste
      </label>
      <select id="krcCqcCopingWaste">
       <option value="5">
        5%
       </option>
       <option value="10" selected="">
        10%
       </option>
       <option value="15">
        15%
       </option>
      </select>
     </div>
    </div>
    <div class="krc-cqc-row" style="grid-template-columns:1fr 1fr;">
     <div class="krc-cqc-block">
      <label for="krcCqcCopingSize">
       Coping Size
      </label>
      <select id="krcCqcCopingSize">
       <option value="24">
        12" x 24"
       </option>
       <option value="24">
        16" x 24"
       </option>
      </select>
     </div>
     <div class="krc-cqc-block">
      <label>
       Unit
      </label>
      <div class="krc-cqc-unit">
       PIECES
      </div>
     </div>
    </div>
    <div class="krc-cqc-boulder-note" style="margin-top:4px;">
     <strong>
      Coping Estimate
     </strong>
     <span>
      Estimate pieces from total linear feet. Final quantities may vary based on cuts, curves, corners, layout, and installation method.
     </span>
    </div>
   </div>
   <div id="krcCqcBoulderNote" class="krc-cqc-boulder-note" style="display:none;">
    <strong>
     Boulder Ordering
    </strong>
    <span>
     Boulders are typically selected by size, weight, and placement rather than square-foot coverage. Add your estimated quantity to the quote cart and our team can help confirm the right amount for your project.
    </span>
   </div>
   <div class="krc-cqc-block" id="krcCqcEzMixWrap" style="display:none;">
    <div class="krc-cqc-row" style="grid-template-columns:1fr 1fr;">
     <div class="krc-cqc-block">
      <label for="krcCqcEzMixLength">
       Length (ft)
      </label>
      <input id="krcCqcEzMixLength" type="number" min="0" step="0.1" placeholder="Ex: 10">
     </div>
     <div class="krc-cqc-block">
      <label for="krcCqcEzMixWidth">
       Width (ft)
      </label>
      <input id="krcCqcEzMixWidth" type="number" min="0" step="0.1" placeholder="Ex: 10">
     </div>
    </div>
    <div class="krc-cqc-row" style="grid-template-columns:1fr 1fr;">
     <div class="krc-cqc-block">
      <label for="krcCqcEzMixThickness">
       Thickness
      </label>
      <select id="krcCqcEzMixThickness">
       <option value="2">
        2 inches
       </option>
       <option value="3">
        3 inches
       </option>
       <option value="4" selected="">
        4 inches
       </option>
       <option value="5">
        5 inches
       </option>
       <option value="6">
        6 inches
       </option>
      </select>
     </div>
     <div class="krc-cqc-block">
      <label for="krcCqcEzMixWaste">
       Waste
      </label>
      <select id="krcCqcEzMixWaste">
       <option value="0">
        0%
       </option>
       <option value="5" selected="">
        5%
       </option>
       <option value="10">
        10%
       </option>
       <option value="15">
        15%
       </option>
      </select>
     </div>
    </div>
    <div class="krc-cqc-boulder-note" style="margin-top:4px;">
     <strong>
      EZ Mix Estimate
     </strong>
     <span>
      Estimates 90 lb bags for slab-style pours only. Coverage is based on approximately 0.675 cubic feet per 90 lb bag. Final needs may vary by subgrade, waste, and application conditions.
     </span>
    </div>
   </div>
   <div class="krc-cqc-block" id="krcCqcOcBlockWrap" style="display:none;">
    <div class="krc-cqc-row" style="grid-template-columns:1fr 1fr;">
     <div class="krc-cqc-block">
      <label for="krcCqcOcBlockLength">
       Wall Length (ft)
      </label>
      <input id="krcCqcOcBlockLength" type="number" min="0" step="0.1" placeholder="Ex: 20">
     </div>
     <div class="krc-cqc-block">
      <label for="krcCqcOcBlockHeight">
       Wall Height (ft)
      </label>
      <input id="krcCqcOcBlockHeight" type="number" min="0" step="0.1" placeholder="Ex: 4">
     </div>
    </div>
    <div class="krc-cqc-row" style="grid-template-columns:1fr 1fr;">
     <div class="krc-cqc-block">
      <label for="krcCqcOcBlockWaste">
       Waste
      </label>
      <select id="krcCqcOcBlockWaste">
       <option value="0">
        0%
       </option>
       <option value="5" selected="">
        5%
       </option>
       <option value="10">
        10%
       </option>
       <option value="15">
        15%
       </option>
      </select>
     </div>
     <div class="krc-cqc-block">
      <label>
       Unit
      </label>
      <div class="krc-cqc-unit">
       BLOCKS
      </div>
     </div>
    </div>
    <div class="krc-cqc-boulder-note" style="margin-top:4px;">
     <strong>
      Block Estimate
     </strong>
     <span>
      Based on standard 8" x 8" x 16" block coverage (approx. 0.89 sq ft per block). Final quantities may vary based on block type, layout, cuts, corners, bond beams, caps, and wall openings.
     </span>
    </div>
   </div>
   <div class="krc-cqc-actions" id="krcCqcCalcActions">
    <button type="button" id="krcCqcCalcBtn">
     Calculate
    </button>
    <button type="button" id="krcCqcResetBtn" class="krc-cqc-reset">
     Reset
    </button>
   </div>
   <div class="krc-cqc-result" id="krcCqcResult" style="display:none;">
    <span id="krcCqcResultLabel">
     Estimated Cubic Yards
    </span>
    <strong id="krcCqcResultValue">
     0
    </strong>
    <div class="krc-cqc-subresult" id="krcCqcSubResult" style="display:none;">
     <span id="krcCqcSubResultLabel">
      Estimated Pallets
     </span>
     <strong id="krcCqcSubResultValue">
      0
     </strong>
    </div>
   </div>
   <button type="button" id="krcCqcAddEstimateBtn" class="krc-cqc-estimate-btn" style="display:none;">
    Add Estimate to Quote
   </button>
                                                                                                                                                                                                        <div class="krc-cqc-divider" id="krcCqcDivider">
                                                                                                                                                                                                        </div>
                                                                                                                                                                                                        <div class="krc-cqc-block" id="krcCqcQtyWrap">
                                                                                                                                                                                                          <label for="krcCqcQty" id="krcCqcQtyLabel">
                                                                                                                                                                                                            Custom Quantity
                                                                                                                                                                                                          </label>
    <div class="krc-cqc-stepper">
     <button type="button" id="krcCqcMinus" class="krc-cqc-stepper-btn" aria-label="Decrease quantity">
      −
     </button>
     <input id="krcCqcQty" class="krc-cqc-stepper-input" type="number" min="0.5" step="0.5" value="1" inputmode="decimal">
     <button type="button" id="krcCqcPlus" class="krc-cqc-stepper-btn" aria-label="Increase quantity">
      +
     </button>
    </div>
   </div>
   <button type="button" id="krcCqcAddCustomBtn" class="krc-cqc-main-btn">
    Add Custom Quantity to Quote
   </button>
   <div class="krc-cqc-msg" id="krcCqcMsg" aria-live="polite">
   </div>
  </div>
  <style>
   #krcCompactQuoteCalc,
    #krcCompactQuoteCalc *{
      box-sizing:border-box;
      font-family:"Cinzel",serif !important;
    }
    #krcCompactQuoteCalc{
      width:100%;
      max-width:420px;
      margin:0;
      position:relative;
      z-index:1;
    }
    #krcCompactQuoteCalc .krc-cqc-card{
      background:linear-gradient(180deg,#ffffff 0%,#fcfbf8 100%);
      border:1px solid rgba(23,33,38,.10);
      border-radius:16px;
      padding:12px;
      box-shadow:0 8px 20px rgba(8,15,20,.05);
    }
    #krcCompactQuoteCalc .krc-cqc-head{
      margin-bottom:10px;
    }
    #krcCompactQuoteCalc .krc-cqc-head h3{
      margin:0 0 3px;
      font-size:16px;
      line-height:1.2;
      font-weight:700;
      color:#172126;
    }
    #krcCompactQuoteCalc .krc-cqc-tip{
      position:relative;
      margin:0 0 8px;
      padding:0 28px;
      font-size:11px;
      line-height:1.45;
      color:#6d7880;
      text-align:center;
    }
    #krcCompactQuoteCalc .krc-cqc-tip-arrow{
      position:absolute;
      top:50%;
      transform:translateY(-50%);
      font-size:12px;
      color:#0b1629;
      display:inline-block;
      will-change:transform, opacity;
      line-height:1;
    }
    #krcCompactQuoteCalc .krc-cqc-tip-arrow-left{
      left:0;
    }
    #krcCompactQuoteCalc .krc-cqc-tip-arrow-right{
      right:0;
    }
    #krcCompactQuoteCalc.is-attention .krc-cqc-tip-arrow-left{
      animation:krcCqcArrowLeft 1s ease-in-out infinite;
    }
    #krcCompactQuoteCalc.is-attention .krc-cqc-tip-arrow-right{
      animation:krcCqcArrowRight 1s ease-in-out infinite;
    }
    #krcCompactQuoteCalc.is-attention .krc-cqc-tip-text{
      animation:krcCqcGlowPulse 1.2s ease-in-out infinite;
      color:#172126;
    }
    #krcCompactQuoteCalc.is-attention #krcCqcAreaWrap{
      position:relative;
    }
    #krcCompactQuoteCalc.is-attention #krcCqcAreaWrap::after{
      content:"";
      position:absolute;
      inset:-5px;
      border-radius:14px;
      pointer-events:none;
      box-shadow:0 0 0 0 rgba(11,22,41,0);
      animation:krcCqcInputGlow 1.2s ease-in-out infinite;
    }
    @keyframes krcCqcArrowLeft{
      0%,100%{ transform:translateY(-50%) translateX(0); opacity:1; }
      50%{ transform:translateY(-50%) translateX(8px); opacity:1; }
    }
    @keyframes krcCqcArrowRight{
      0%,100%{ transform:translateY(-50%) translateX(0); opacity:1; }
      50%{ transform:translateY(-50%) translateX(-8px); opacity:1; }
    }
    @keyframes krcCqcGlowPulse{
      0%,100%{ opacity:1; }
      50%{ opacity:.45; }
    }
   @keyframes krcCqcInputGlow{
  0%,100%{ box-shadow:0 0 0 0 rgba(11,22,41,0); }
  50%{ box-shadow:0 0 0 4px rgba(11,22,41,.08); }
}
    #krcCompactQuoteCalc .krc-cqc-row{
      display:grid;
      grid-template-columns:1fr 110px;
      gap:8px;
    }
    #krcCompactQuoteCalc .krc-cqc-block{
      margin-bottom:8px;
    }
    #krcCompactQuoteCalc label{
      display:block;
      margin-bottom:4px;
      font-size:9px;
      font-weight:600;
      letter-spacing:.05em;
      text-transform:uppercase;
      color:#172126;
    }
    #krcCompactQuoteCalc input,
    #krcCompactQuoteCalc select{
      width:100%;
      height:34px;
      border:1px solid rgba(23,33,38,.10);
      border-radius:10px;
      background:#fff;
      padding:0 10px;
      font-size:13px;
      color:#223a35;
      position:relative;
      z-index:2;
      pointer-events:auto;
    }
    #krcCompactQuoteCalc input:focus,
    #krcCompactQuoteCalc select:focus{
      outline:none;
      border-color:#b9cec7;
      box-shadow:0 0 0 4px rgba(40,69,63,.06);
    }
    #krcCompactQuoteCalc .krc-cqc-unit{
      height:34px;
      border-radius:10px;
      border:1px solid #d6d8dc;
      background:#f2f3f5;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:9px;
      font-weight:600;
      letter-spacing:.05em;
      text-transform:uppercase;
      color:#2a2e33;
    }
    #krcCompactQuoteCalc .krc-cqc-boulder-note{
      margin:4px 0 10px;
      padding:10px 12px;
      border:1px solid rgba(23,33,38,.10);
      border-radius:12px;
      background:#f8f8f6;
      color:#172126;
    }
    #krcCompactQuoteCalc .krc-cqc-boulder-note strong{
      display:block;
      margin-bottom:4px;
      font-size:10px;
      text-transform:uppercase;
      letter-spacing:.05em;
    }
    #krcCompactQuoteCalc .krc-cqc-boulder-note span{
      display:block;
      font-size:10px;
      line-height:1.5;
    }
    #krcCompactQuoteCalc .krc-cqc-actions{
      display:grid;
      grid-template-columns:1fr 84px;
      gap:8px;
      margin:4px 0 8px;
    }
    #krcCompactQuoteCalc button{
      position:relative;
      z-index:3;
      pointer-events:auto;
      transition:transform .18s ease, background-color .18s ease, box-shadow .18s ease, opacity .18s ease;
    }
    #krcCompactQuoteCalc #krcCqcCalcBtn,
    #krcCompactQuoteCalc .krc-cqc-main-btn,
    #krcCompactQuoteCalc .krc-cqc-estimate-btn{
      min-height:34px;
      border:none;
      border-radius:999px;
      background:#0b1629;
      color:#fff;
      font-size:9px;
      font-weight:600;
      letter-spacing:.05em;
      text-transform:uppercase;
      cursor:pointer;
      box-shadow:0 8px 18px rgba(11,22,41,.16);
        #krcCompactQuoteCalc .krc-cqc-main-btn{
          min-height:30px;
          font-size:8px;
          letter-spacing:.04em;
          padding:0 14px;
        }
    }
    #krcCompactQuoteCalc #krcCqcCalcBtn:hover,
    #krcCompactQuoteCalc .krc-cqc-main-btn:hover,
    #krcCompactQuoteCalc .krc-cqc-estimate-btn:hover{
      background:#11213c;
      transform:translateY(-1px);
    }
    #krcCompactQuoteCalc .krc-cqc-reset{
      min-height:34px;
      border-radius:999px;
      border:1px solid #e5e7eb;
      background:#f3f4f6;
      color:#111827;
      font-size:9px;
      font-weight:600;
      letter-spacing:.05em;
      text-transform:uppercase;
      cursor:pointer;
    }
    #krcCompactQuoteCalc .krc-cqc-result{
      background:#f9fafb;
      border:1px solid #e5e7eb;
      border-radius:12px;
      padding:10px;
      text-align:center;
      margin-bottom:8px;
    }
    #krcCompactQuoteCalc .krc-cqc-result span{
      display:block;
      margin-bottom:3px;
      font-size:8px;
      font-weight:600;
      letter-spacing:.06em;
      text-transform:uppercase;
      color:#6b7280;
    }
    #krcCompactQuoteCalc .krc-cqc-result strong{
      display:block;
      font-size:22px;
      line-height:1;
      font-weight:800;
      color:#172126;
    }
    #krcCompactQuoteCalc .krc-cqc-subresult{
      margin-top:10px;
      padding-top:10px;
      border-top:1px solid rgba(23,33,38,.08);
    }
    #krcCompactQuoteCalc .krc-cqc-subresult strong{
      font-size:18px;
    }
    #krcCompactQuoteCalc .krc-cqc-estimate-btn{
      width:100%;
      margin-bottom:10px;
      background:#d8e7df;
      color:#172126;
      box-shadow:none;
    }
    #krcCompactQuoteCalc .krc-cqc-estimate-btn:hover{
      background:#cddfd6;
    }
    #krcCompactQuoteCalc .krc-cqc-divider{
      height:1px;
      background:rgba(23,33,38,.08);
      margin:10px 0;
    }
        #krcCompactQuoteCalc .krc-cqc-stepper{
      display:grid;
      grid-template-columns:34px 1fr 34px;
      gap:6px;
      align-items:center;
    }
    #krcCompactQuoteCalc .krc-cqc-stepper-btn{
      width:34px;
      height:34px;
      border:1px solid rgba(23,33,38,.10);
      border-radius:10px;
      background:#fff;
      color:#223a35;
      font-size:18px;
      line-height:1;
      cursor:pointer;
      padding:0;
    }
    #krcCompactQuoteCalc .krc-cqc-stepper-input{
      text-align:center;
      font-weight:700;
      appearance:textfield;
      -moz-appearance:textfield;
    }
    #krcCompactQuoteCalc .krc-cqc-stepper-input::-webkit-outer-spin-button,
    #krcCompactQuoteCalc .krc-cqc-stepper-input::-webkit-inner-spin-button{
      -webkit-appearance:none;
      margin:0;
    }
    #krcCompactQuoteCalc .krc-cqc-main-btn{
      width:100%;
    }
    #krcCompactQuoteCalc .krc-cqc-msg{
      margin-top:8px;
      display:none;
      padding:8px 10px;
      border-radius:10px;
      border:1px solid #c4d7d0;
      background:#eef6f2;
      color:#1f5f46;
      font-size:11px;
      font-weight:600;
    }
    #krcCompactQuoteCalc .krc-cqc-msg.is-visible{
      display:block;
    }
    #krcCompactQuoteCalc .krc-cqc-msg.is-error{
      border-color:#e3c1c1;
      background:#fbefef;
      color:#8b2f2f;
    }
    #krcCompactQuoteCalc .krc-cqc-btn-success{
      background:#2f7a55 !important;
      color:#fff !important;
      box-shadow:0 10px 22px rgba(47,122,85,.26) !important;
      transform:translateY(-1px) scale(1.02);
    }
    #krcCompactQuoteCalc .krc-cqc-btn-pop{
      animation:krcCqcBtnPop .36s ease;
