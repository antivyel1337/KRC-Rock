    function getOcBlockFaceArea(){
  var s = getPageSignals();
  var text = normalize([s.name, s.title, s.slug, s.category, s.subcategory].join(" "));
  if(text.indexOf("8x8x8") > -1 || text.indexOf("8 x 8 x 8") > -1){
    return (8 * 8) / 144; // 0.4444 sq ft per block face
  }
  if(text.indexOf("6x8x8") > -1 || text.indexOf("6 x 8 x 8") > -1){
    return (8 * 8) / 144; // treated as 8x8 face
  }
  if(text.indexOf("6x8x16") > -1 || text.indexOf("6 x 8 x 16") > -1){
    return (16 * 8) / 144; // 0.8889 sq ft
  }
  if(text.indexOf("8x8x16") > -1 || text.indexOf("8 x 8 x 16") > -1){
    return (16 * 8) / 144; // 0.8889 sq ft
  }
  if(text.indexOf("12x8x16") > -1 || text.indexOf("12 x 8 x 16") > -1){
    return (16 * 8) / 144; // face still 16x8
  }
  return (16 * 8) / 144;
}
